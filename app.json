{
  "expo": {
    "name": "ADRS Cam",
    "slug": "adrs-cam",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adrs.cam",
      "infoPlist": {
        "NSCameraUsageDescription": "ADRS requires camera access for draft reading"
      }
    },
    "android": {
      "package": "com.adrs.cam",
      "permissions": ["android.permission.CAMERA"],
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "plugins": [
      "expo-dev-client",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "ADRS requires camera access for draft reading"
        }
      ]
    ]
  }
}
